        "click": "button[title='Add Ambient & Base']"
      },
      {
        "wait": 800
      },
      {
        "click": ".svelte-flow__node:has-text('Solid Base'), .svelte-flow__node:has-text('Whole Drum'), .svelte-flow__node:has-text('Whole Kit'), .svelte-flow__node:has-text('Chase Bands')"
      },
      {
        "wait": 600
      },
      {
        "click": "button[aria-label='Change effect']",
        "force": true
      },
      {
        "wait": 600
      }
    ],
    "select": ".dlg-gallery",
    "settle": 1200
  },
