{
  "shell": {
    "route": "?view=trigger"
  },
  "top-bar": {
    "route": "?view=trigger",
    "select": ".top"
  },
  "transport": {
    "route": "?view=trigger",
    "select": ".xport"
  },
  "left-rail": {
    "route": "?view=trigger",
    "select": ".rail"
  },
  "trigger-graph": {
    "route": "?view=trigger",
    "select": "main.center"
  },
  "node-editor-add": {
    "route": "?view=trigger",
    "select": ".node-editor"
  },
  "trigger-node-selected": {
    "route": "?view=trigger",
    "actions": [
      {
        "click": ".svelte-flow__node"
      }
    ],
    "select": ".node-editor"
  },
  "graphs-dock": {
    "route": "?view=trigger",
    "select": ".graphbar"
  },
  "visualizer": {
    "route": "?view=trigger",
    "select": "aside.col2 .viz",
    "settle": 1500
  },
  "buses": {
    "route": "?view=trigger",
    "select": "aside.col2 .buses"
  },
  "patch-graph": {
    "route": "?view=patch",
    "select": "main.center",
    "settle": 1500
  },
  "objects": {
    "route": "?view=objects",
    "select": "main.center"
  },
  "song-library": {
    "route": "?view=objects",
    "actions": [
      {
        "click": "text=Song Library"
      }
    ],
    "select": "main.center"
  },
  "sections": {
    "route": "?view=sections",
    "select": "main.center"
  },
  "section-detail": {
    "route": "?view=sections",
    "actions": [
      {
        "click": "section.col .li"
      },
      {
        "wait": 300
      }
    ],
    "select": "main.center"
  },
  "perform": {
    "route": "?view=perform"
  },
  "monitor": {
    "route": "?view=monitor",
    "select": "main.center"
  },
  "settings-dialog": {
    "route": "?view=trigger",
    "actions": [
      {
        "click": "button[aria-label=\"Settings\"]"
      },
      {
        "wait": 400
      }
    ]
  },
  "node-editor-play": {
    "route": "?view=trigger",
    "actions": [
      {
        "click": ".svelte-flow__node[data-id*='play'], .svelte-flow__node:has(.thumb)"
      }
    ],
    "select": ".node-editor"
  },
  "patch-controller": {
    "route": "?view=patch",
    "actions": [
      {
        "click": ".svelte-flow__node[data-id='controller']"
      },
      {
        "wait": 400
      }
    ],
    "select": ".node-editor",
    "settle": 1500
  },
  "effect-gallery": {
    "route": "?view=trigger",
    "actions": [
      {
        "click": "button:has-text('Take over')",
        "force": true
      },
      {
        "wait": 500
      },
      {
        "click": ".svelte-flow__node[data-id*='play'], .svelte-flow__node:has(.thumb)"
      },
      {
        "wait": 600
      },
      {
        "click": "button[aria-label='Change effect']",
        "force": true
      },
      {
        "wait": 600
      }
    ],
    "select": ".dlg-gallery",
    "settle": 1200
  },
  "effect-gallery-collection": {
    "route": "?view=trigger",
    "actions": [
      {
        "click": "button:has-text('Take over')",
        "force": true
      },
      {
        "wait": 500
      },
      {
        "click": ".svelte-flow__node[data-id*='play'], .svelte-flow__node:has(.thumb)"
      },
      {
        "wait": 600
      },
      {
        "click": "button[aria-label='Change effect']",
        "force": true
      },
      {
        "wait": 600
      },
      {
        "click": ".dlg-gallery .tabs-trigger:has-text('Particles')"
      },
      {
        "wait": 600
      }
    ],
    "select": ".dlg-gallery",
    "settle": 1200
  },
  "effect-gallery-filtered": {
    "route": "?view=trigger",
    "actions": [
      {
        "click": "button:has-text('Take over')",
        "force": true
      },
      {
        "wait": 500
      },
      {
        "click": ".svelte-flow__node[data-id*='play'], .svelte-flow__node:has(.thumb)"
      },
      {
        "wait": 600
      },
      {
        "click": "button[aria-label='Change effect']",
        "force": true
      },
      {
        "wait": 600
      },
      {
        "click": ".dlg-gallery .seg-btn:has-text('Kit')"
      },
      {
        "wait": 600
      },
      {
        "click": ".dlg-gallery .tagrow button:has-text('texture')"
      },
      {
        "wait": 600
      }
    ],
    "select": ".dlg-gallery",
    "settle": 1200
  }
}