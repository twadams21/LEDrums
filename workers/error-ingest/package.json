{
  "name": "@ledrums/error-ingest-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker: batch error-report ingest → D1, token-authed read API, Discord webhook (#122).",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "deploy": "npx wrangler@4 deploy",
    "db:init:remote": "npx wrangler@4 d1 execute ledrums-errors --remote --file=./schema.sql",
    "db:init:local": "npx wrangler@4 d1 execute ledrums-errors --local --file=./schema.sql"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
