# Intermediate sidecar build artifacts + staged web bundle (regenerated by the build scripts).
sidecar/
web-dist/
# Generated bootstrap shell: main.bundle.js (esbuild) + index.html (token-substituted from
# shell/index.template.html + the web token file). Source of truth = the template + tokens.css.
shell/main.bundle.js
shell/index.html

# Pinned Node LTS cached by build-sidecar.mjs (the postject-safe SEA base) — per-machine, large.
.node-pin/

# The built sidecar binary + fetched cloudflared are per-machine, per-platform artifacts —
# produced by build:sidecar / fetch:cloudflared, never committed. The dirs themselves are kept
# (via .gitkeep) so Tauri's externalBin/resources paths always exist.
src-tauri/binaries/ledrums-server-*
src-tauri/cloudflared/cloudflared
src-tauri/cloudflared/cloudflared.exe
