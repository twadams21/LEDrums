{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "app",
  "description": "Main app window. Starts on the bundled loading shell, then navigates to the local server. Grants minimal IPC for manual updater checks.",
  "windows": ["app"],
  "remote": {
    "urls": ["http://127.0.0.1:*", "http://localhost:*"]
  },
  "permissions": [
    "core:default",
    "clipboard-manager:allow-write-text",
    "allow-get-boot-status",
    "allow-check-for-update-now",
    "allow-install-update-now"
  ]
}
