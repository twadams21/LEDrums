{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LEDrums",
  "version": "0.2.7",
  "identifier": "app.ledrums.desktop",
  "build": {
    "beforeDevCommand": "node scripts/prepare-bundle.mjs",
    "beforeBuildCommand": "node scripts/prepare-bundle.mjs",
    "frontendDist": "../shell"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "app",
        "title": "LEDrums",
        "url": "index.html",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ledrums-server"
    ],
    "resources": {
      "../web-dist": "web-dist",
      "cloudflared": "cloudflared"
    },
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://pub-6ba98981a8804912b9551135ba976ef4.r2.dev/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk2NEMzRDY1MDY2OEExNTEKUldSUm9XZ0daVDFNbGlqL1BjU3pUbkdwd21SZVY2MzR0Wjk2bDZJaE9CVk9EcEVPNGhwcUx6L0IK"
    }
  }
}
